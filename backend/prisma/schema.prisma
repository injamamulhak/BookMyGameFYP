// ============================================
// BookMyGame - Complete Prisma Schema
// PERN Stack with PostgreSQL + Prisma ORM
// Student: Md Injamamul Haque (23049321)
// 
// FEATURES INCLUDED (ALL from approved proposal):
// ✅ Admin approval workflow for venues
// ✅ Day-wise operating hours
// ✅ User preferences & favorite venues
// ✅ Training videos (instructional content)
// ✅ Sports gear marketplace (admin-only)
// ✅ Event registration system
// ✅ In-app notifications
// ✅ Payment tracking (Khalti integration)
// ✅ Multiple venue images
// ✅ Reviews & ratings system
// ✅ GiST overlap prevention (added via migration)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  user
  operator // Changed from venue_owner to match proposal
  admin
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

enum PaymentStatus {
  pending
  completed
  failed
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum EventType {
  tournament
  league
  training
}

enum DifficultyLevel {
  beginner
  intermediate
  advanced
}

enum OrderStatus {
  pending
  completed
  cancelled
}

// ============================================
// CORE USER SYSTEM
// ============================================

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique @db.VarChar(255)
  passwordHash            String    @map("password_hash")
  fullName                String    @map("full_name") @db.VarChar(255)
  phone                   String?   @db.VarChar(20)
  role                    UserRole  @default(user)
  profileImage            String?   @map("profile_image")
  isVerified              Boolean   @default(false) @map("is_verified")
  verificationToken       String?   @unique @map("verification_token")
  verificationTokenExpiry DateTime? @map("verification_token_expiry")
  verifiedAt              DateTime? @map("verified_at")

  // Password reset fields
  resetToken       String?   @unique @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  preferences         UserPreference?
  preferredSports     UserPreferredSport[]
  favoriteVenues      UserFavoriteVenue[]
  ownedVenues         Venue[]              @relation("VenueOperator")
  approvedVenues      Venue[]              @relation("VenueApprover")
  bookings            Booking[]
  reviews             Review[]
  eventRegistrations  EventRegistration[]
  orders              Order[]
  payments            Payment[]
  notifications       Notification[]
  productsSelling     Product[]            @relation("ProductSeller")
  canSellProducts     Boolean              @default(false) @map("can_sell_products")
  sellerRequestStatus String               @default("none") @map("seller_request_status") @db.VarChar(20)
  // Video upload fields
  canUploadVideos     Boolean              @default(false) @map("can_upload_videos")
  videoUploaderRequestStatus String        @default("none") @map("video_uploader_request_status") @db.VarChar(20)
  uploadedVideos      TrainingVideo[]      @relation("VideoUploader")
  ReviewReply         ReviewReply[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model UserPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  preferredLocation   String?  @map("preferred_location") @db.VarChar(200)
  preferredLatitude   Decimal? @map("preferred_latitude") @db.Decimal(10, 8)
  preferredLongitude  Decimal? @map("preferred_longitude") @db.Decimal(11, 8)
  maxDistanceKm       Int      @default(10) @map("max_distance_km")
  preferredPriceMin   Decimal? @map("preferred_price_min") @db.Decimal(10, 2)
  preferredPriceMax   Decimal? @map("preferred_price_max") @db.Decimal(10, 2)
  notificationEnabled Boolean  @default(true) @map("notification_enabled")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ============================================
// SPORTS SYSTEM
// ============================================

model Sport {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  description String?
  iconUrl     String?  @map("icon_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  userPreferences UserPreferredSport[]
  venues          Venue[]
  trainingVideos  TrainingVideo[]

  @@map("sports")
}

model UserPreferredSport {
  userId  String @map("user_id")
  sportId String @map("sport_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@id([userId, sportId])
  @@map("user_preferred_sports")
}

// ============================================
// VENUE SYSTEM (with Admin Approval)
// ============================================

model Venue {
  id           String   @id @default(uuid())
  operatorId   String   @map("operator_id")
  sportId      String   @map("sport_id")
  name         String   @db.VarChar(255)
  description  String?
  address      String
  city         String?  @db.VarChar(100)
  state        String?  @db.VarChar(100)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  pricePerHour Decimal  @map("price_per_hour") @db.Decimal(10, 2)
  contactPhone String?  @map("contact_phone") @db.VarChar(20)
  contactEmail String?  @map("contact_email") @db.VarChar(255)
  amenities    Json?

  // ADMIN APPROVAL WORKFLOW
  approvalStatus  ApprovalStatus @default(pending) @map("approval_status")
  approvedBy      String?        @map("approved_by")
  approvedAt      DateTime?      @map("approved_at")
  rejectionReason String?        @map("rejection_reason")

  isActive     Boolean  @default(true) @map("is_active")
  rating       Decimal  @default(0.00) @db.Decimal(3, 2)
  totalReviews Int      @default(0) @map("total_reviews")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  operator       User                 @relation("VenueOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  approver       User?                @relation("VenueApprover", fields: [approvedBy], references: [id])
  sport          Sport                @relation(fields: [sportId], references: [id])
  operatingHours VenueOperatingHour[]
  images         VenueImage[]
  favoritedBy    UserFavoriteVenue[]
  timeSlots      TimeSlot[]
  reviews        Review[]
  events         Event[]

  @@index([operatorId])
  @@index([sportId])
  @@index([city])
  @@index([isActive])
  @@index([approvalStatus])
  @@index([latitude, longitude])
  @@map("venues")
}

// DAY-WISE OPERATING HOURS
model VenueOperatingHour {
  id          String    @id @default(uuid())
  venueId     String    @map("venue_id")
  dayOfWeek   Int       @map("day_of_week") // 0=Sunday, 1=Monday, ..., 6=Saturday
  isClosed    Boolean   @default(false) @map("is_closed")
  openingTime DateTime? @map("opening_time") @db.Time
  closingTime DateTime? @map("closing_time") @db.Time
  createdAt   DateTime  @default(now()) @map("created_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, dayOfWeek])
  @@index([venueId])
  @@map("venue_operating_hours")
}

// NOTE: VenueSport junction table removed - using Venue.sportId instead

// VENUE IMAGES - Simple storage (sport inferred from venue)
model VenueImage {
  id           String   @id @default(uuid())
  venueId      String   @map("venue_id")
  imageUrl     String   @map("image_url")
  isPrimary    Boolean  @default(false) @map("is_primary")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@map("venue_images")
}

model UserFavoriteVenue {
  userId    String   @map("user_id")
  venueId   String   @map("venue_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@id([userId, venueId])
  @@map("user_favorite_venues")
}

// ============================================
// BOOKING SYSTEM
// ============================================

// TimeSlot model (matches your proposal: users book venue time slots)
model TimeSlot {
  id        String    @id @default(uuid())
  venueId   String    @map("venue_id")
  date      DateTime  @db.Date
  startTime DateTime  @map("start_time") @db.Time
  endTime   DateTime  @map("end_time") @db.Time
  price     Decimal   @db.Decimal(10, 2)
  lockedBy  String?   @map("locked_by") @db.VarChar(36)
  lockedAt  DateTime? @map("locked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  venue    Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([venueId, date])
  @@map("time_slots")
}

model Booking {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  slotId      String        @map("slot_id")
  totalPrice  Decimal       @map("total_price") @db.Decimal(10, 2)
  status      BookingStatus @default(pending)
  notes       String?
  bookingDate DateTime      @default(now()) @map("booking_date")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  slot     TimeSlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  payments Payment[]
  review   Review?

  @@index([userId])
  @@index([slotId])
  @@index([status])
  @@map("bookings")
}

// PAYMENT TRACKING - Separate Table for Khalti Integration
model Payment {
  id              String        @id @default(uuid())
  bookingId       String?       @map("booking_id")
  orderId         String?       @map("order_id")
  registrationId  String?       @map("registration_id")
  userId          String        @map("user_id")
  amount          Decimal       @db.Decimal(10, 2)
  paymentMethod   String        @default("khalti") @map("payment_method") @db.VarChar(50)
  transactionId   String?       @unique @map("transaction_id") @db.VarChar(255)
  status          PaymentStatus @default(pending)
  gatewayResponse Json?         @map("gateway_response")
  refundAmount    Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  refundedAt      DateTime?     @map("refunded_at")
  refundStatus    String?       @map("refund_status") @db.VarChar(20)
  refundPidx      String?       @map("refund_pidx") @db.VarChar(255)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  booking      Booking?           @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  order        Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  registration EventRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([orderId])
  @@index([registrationId])
  @@index([userId])
  @@index([status])
  @@map("payments")
}

// ============================================
// REVIEWS SYSTEM
// ============================================

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  venueId   String   @map("venue_id")
  bookingId String?  @unique @map("booking_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isFlagged Boolean  @default(false) @map("is_flagged")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue   Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  booking Booking?      @relation(fields: [bookingId], references: [id])
  replies ReviewReply[]

  @@index([venueId])
  @@index([userId])
  @@map("reviews")
}

model ReviewReply {
  id        String   @id @default(uuid())
  reviewId  String   @map("review_id")
  userId    String   @map("user_id")
  comment   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_replies")
}

// ============================================
// EVENTS SYSTEM (with Registration)
// ============================================

model Event {
  id                   String    @id @default(uuid())
  venueId              String    @map("venue_id")
  title                String    @db.VarChar(255)
  description          String?
  eventType            EventType @map("event_type")
  startDate            DateTime  @map("start_date") @db.Date
  endDate              DateTime  @map("end_date") @db.Date
  startTime            DateTime? @map("start_time") @db.Time
  endTime              DateTime? @map("end_time") @db.Time
  slots                Json? // Precise non-contiguous blocked slots array [{date, startTime, endTime}]
  registrationFee      Decimal   @default(0) @map("registration_fee") @db.Decimal(10, 2)
  maxParticipants      Int?      @map("max_participants")
  imageUrl             String?   @map("image_url")
  isFeatured           Boolean   @default(false) @map("is_featured")
  registrationDeadline DateTime? @map("registration_deadline")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  venue         Venue               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]

  @@index([venueId])
  @@index([startDate, endDate])
  @@map("events")
}

// EVENT REGISTRATION
model EventRegistration {
  id            String        @id @default(uuid())
  eventId       String        @map("event_id")
  userId        String        @map("user_id")
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  registeredAt  DateTime      @default(now()) @map("registered_at")

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_registrations")
}

// ============================================
// TRAINING SYSTEM (Instructional Videos)
// ============================================

model TrainingVideo {
  id              String           @id @default(uuid())
  sportId         String?          @map("sport_id")
  uploaderId      String?          @map("uploader_id")
  title           String           @db.VarChar(255)
  description     String?
  videoUrl        String           @map("video_url")
  thumbnailUrl    String?          @map("thumbnail_url")
  duration        Int? // in seconds
  difficultyLevel DifficultyLevel? @map("difficulty_level")
  viewCount       Int              @default(0) @map("view_count")
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  sport          Sport?  @relation(fields: [sportId], references: [id], onDelete: SetNull)
  uploader       User?   @relation("VideoUploader", fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([sportId])
  @@index([uploaderId])
  @@index([difficultyLevel])
  @@map("training_videos")
}

// ============================================
// MARKETPLACE - Sports Gear Shop (Admin Only)
// ============================================

model Product {
  id            String   @id @default(uuid())
  sellerId      String?  @map("seller_id")
  name          String   @db.VarChar(255)
  description   String?
  category      String   @db.VarChar(100)
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(10, 2)
  stock         Int      @default(0)
  imageUrl      String?  @map("image_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  seller     User?       @relation("ProductSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]

  @@index([category])
  @@index([isActive])
  @@index([sellerId])
  @@map("products")
}

model Order {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  status          OrderStatus @default(pending)
  shippingAddress String?     @map("shipping_address")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    OrderItem[]
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

// ============================================
// NOTIFICATIONS (In-App Alerts)
// ============================================

model Notification {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  type              String   @db.VarChar(50)
  title             String   @db.VarChar(255)
  message           String
  isRead            Boolean  @default(false) @map("is_read")
  relatedEntityType String?  @map("related_entity_type") @db.VarChar(50)
  relatedEntityId   String?  @map("related_entity_id")
  link              String?  @db.VarChar(500)
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// ============================================
// CONTACT INQUIRIES
// ============================================

model ContactInquiry {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  subject   String   @db.VarChar(255)
  message   String   @db.Text
  status    String   @default("pending") @db.VarChar(50) // pending, resolved
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("contact_inquiries")
}
