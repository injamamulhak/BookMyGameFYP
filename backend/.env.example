# Environment Variables
NODE_ENV=development
PORT=5000

# Database Configuration (for Prisma)
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/bookmygame?schema=public"

# Legacy DB Config (can be removed if only using Prisma)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookmygame
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Khalti Payment Gateway
KHALTI_SECRET_KEY=your_khalti_secret_key_here
KHALTI_PUBLIC_KEY=your_khalti_public_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Email Configuration
# Gmail SMTP Settings
# NOTE: For Gmail, you need to generate an App Password:
# 1. Go to Google Account Settings > Security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords (search for it)
# 4. Generate a new app password for "Mail"
# 5. Use that 16-character password below
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM="BookMyGame <noreply@bookmygame.com>"
